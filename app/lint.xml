<?xml version="1.0" encoding="UTF-8"?>
<!--
  Android Lint 설정 파일
  참고: https://googlesamples.github.io/android-custom-lint-rules/usage/lintxml.md.html
-->
<lint>
    <!-- 전체 설정 -->
    <issue id="all" severity="warning" />

    <!-- ========== 보안 관련 (Security) ========== -->
    <issue id="HardcodedDebugMode" severity="error" />
    <issue id="AllowBackup" severity="warning" />
    <issue id="ExportedContentProvider" severity="error" />
    <issue id="ExportedReceiver" severity="error" />
    <issue id="ExportedService" severity="error" />
    <issue id="GrantAllUris" severity="error" />
    <issue id="SecureRandom" severity="error" />
    <issue id="SetWorldReadable" severity="error" />
    <issue id="SetWorldWritable" severity="error" />
    <issue id="TrustAllX509TrustManager" severity="error" />
    <issue id="UnprotectedSMSBroadcastReceiver" severity="error" />
    <issue id="UnsafeProtectedBroadcastReceiver" severity="error" />
    <issue id="WorldReadableFiles" severity="error" />
    <issue id="WorldWriteableFiles" severity="error" />

    <!-- ========== 성능 관련 (Performance) ========== -->
    <issue id="DrawAllocation" severity="error" />
    <issue id="Recycle" severity="error" />
    <issue id="ObsoleteLayoutParam" severity="warning" />
    <issue id="ObsoleteSdkInt" severity="warning" />
    <issue id="Overdraw" severity="warning" />
    <issue id="UseSparseArrays" severity="warning" />
    <issue id="UseCompoundDrawables" severity="warning" />
    <issue id="StaticFieldLeak" severity="error" />
    <issue id="ViewHolder" severity="warning" />
    <issue id="HandlerLeak" severity="error" />
    <issue id="WakelockTimeout" severity="error" />
    <issue id="UnusedResources" severity="warning" />

    <!-- ========== 정확성 관련 (Correctness) ========== -->
    <issue id="DefaultLocale" severity="warning" />
    <issue id="GradleDeprecated" severity="error" />
    <issue id="InlinedApi" severity="error" />
    <issue id="InvalidPackage" severity="error" />
    <issue id="MissingPermission" severity="error" />
    <issue id="NewApi" severity="error" />
    <issue id="PrivateResource" severity="warning" />
    <issue id="Range" severity="error" />
    <issue id="ResourceType" severity="error" />
    <issue id="SdkInt" severity="warning" />
    <issue id="SimpleDateFormat" severity="warning" />
    <issue id="UnusedAttribute" severity="warning" />
    <issue id="WrongConstant" severity="error" />
    <issue id="WrongThread" severity="error" />
    <issue id="MissingSuperCall" severity="error" />

    <!-- ========== 접근성 관련 (Accessibility) ========== -->
    <issue id="ContentDescription" severity="warning" />
    <issue id="LabelFor" severity="warning" />
    <issue id="TouchTargetSizeCheck" severity="warning" />

    <!-- ========== 국제화 관련 (Internationalization) ========== -->
    <issue id="HardcodedText" severity="error" />
    <issue id="RelativeOverlap" severity="warning" />
    <issue id="RtlCompat" severity="warning" />
    <issue id="RtlEnabled" severity="warning" />
    <issue id="RtlHardcoded" severity="warning" />
    <issue id="RtlSymmetry" severity="warning" />
    <issue id="SetTextI18n" severity="warning" />
    <issue id="Typos" severity="warning" />

    <!-- ========== 코드 스타일 (Style) ========== -->
    <issue id="UseTomlInstead" severity="warning" />

    <!-- ========== Compose 관련 ========== -->
    <issue id="ComposeModifierMissing" severity="warning" />
    <issue id="ComposeModifierReused" severity="warning" />
    <issue id="ComposeModifierWithoutDefault" severity="warning" />
    <issue id="ComposePreviewNaming" severity="warning" />
    <issue id="ComposePreviewPublic" severity="warning" />
    <issue id="ComposeRememberMissing" severity="error" />
    <issue id="ComposeUnstableCollections" severity="warning" />

    <!-- ========== Kotlin Interop ========== -->
    <issue id="UnknownNullness" severity="warning" />

    <!-- ========== 무시할 규칙 ========== -->
    <!-- Test 코드에서는 일부 규칙 완화 -->
    <issue id="MissingTranslation" severity="ignore">
        <ignore path="**/test/**" />
        <ignore path="**/androidTest/**" />
    </issue>

    <!-- Compose Preview에서 hardcoded text 허용 -->
    <issue id="HardcodedText">
        <ignore regexp=".*Preview.*" />
    </issue>

    <!-- Generated 코드 무시 -->
    <issue id="all">
        <ignore path="**/generated/**" />
        <ignore path="**/build/**" />
    </issue>
</lint>
